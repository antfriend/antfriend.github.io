\section*{Mathematical TTDB}
This LaTeX TTDB specifies generalized mathematical processing for TTDB features used in \texttt{index.html} and \texttt{banjo/banjo.html}. It is intended as an implementation-neutral reference model.

\begin{ttdb_mmpdb}
db_id: ttdb:mathematical:processing:v1
db_name: "Mathematical"
coord_increment:
  lat: 1
  lon: 1
collision_policy: southeast_step
timestamp_kind: unix_utc
umwelt:
  umwelt_id: umwelt:tte:mathematical:model:v1
  role: process_librarian
  perspective: "A formal model of TTDB parsing, cursoring, rendering, interaction, and stochastic reveal."
  scope: "Features represented in index.html and banjo/banjo.html."
  constraints:
    - "Use deterministic transforms where possible."
    - "Preserve typed-edge directionality."
    - "Treat random card choice as explicit stochastic sampling."
  globe:
    frame: "unit_sphere_knowledge_globe"
    origin: "Record coordinates are points on a subjective globe."
    mapping: "Record ID @LATxLONy maps to spherical coordinates (phi, lambda) in degrees."
    note: "Projection and visibility are camera-dependent."
cursor_policy:
  max_preview_chars: 280
  max_nodes: 80
typed_edges:
  enabled: true
  syntax: "type>@TARGET_ID"
  note: "Edges are directed and canonical in header metadata."
librarian:
  enabled: true
  primitive_queries:
    - "SELECT <record_id>"
    - "FIND <token>"
    - "EDGES <record_id>"
    - "STATUS"
  max_reply_chars: 280
  invocation_prefix: "@AI"
\end{ttdb_mmpdb}

